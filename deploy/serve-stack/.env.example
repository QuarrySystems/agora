# deploy/serve-stack/.env — copy to `.env` in this directory and fill in.
# docker-compose reads this file directly (env_file: .env on serve, plus
# ${...} interpolation against the project-local .env) — no export step.

# Anthropic API key — serve-side ONLY. Staged per-dispatch through the
# LocalStack Secrets Manager lane; the laptop never holds it.
ANTHROPIC_API_KEY=

# GID of the host's /var/run/docker.sock, so the non-root serve user (uid 1000)
# can launch sibling workers. Find it with:
# $(docker run --rm -v /var/run/docker.sock:/var/run/docker.sock alpine stat -c '%g' /var/run/docker.sock)
# Leave empty to use the compose default (999 — matches most Linux hosts).
DOCKER_GID=
